<ROOT>
   <CONFIG>
      <IP_NUMBER>192.168.178.22</IP_NUMBER>
      <!-- IP-number of the external socket -->
      <PORT>4000</PORT>
      <!-- Port-number of the external socket -->
      <SENTYPE>ImFree</SENTYPE>
      <!-- The name of your system send in <Sen Type="" > -->
      <ONLYSEND>TRUE</ONLYSEND>
      <!-- TRUE means the client don't expect answers. Do not send anything to robot -->
   </CONFIG>

   <!-- RSI Data: TYPE=  "BOOL", "STRING", "LONG", "DOUBLE" -->
   <!-- INDX= "INTERNAL" switch on internal read values. Needed by DEF_... -->
   <!-- INDX= "nmb" Input/Output index of RSI-Object / Maximum of RSI Channels: 64  -->
   <!-- HOLDON="1", set this output index of RSI Object to the last value  -->
   <!-- DEF_Delay count the late packages and send it back to server  -->
   <!-- DEF_Tech: .T = advance .C = main run / .T1 advance set function generator 1 -->

   <!-- DEMO-SERVER CONFIG -->
   <!-- TAG names use underscores (no dots) to match the nebumind sp-dashboard    -->
   <!-- column name requirements. XML parsing is done by the RSI objects in the   -->
   <!-- .rsix (PosAct, MotorCurrent, Sen_PInt) — the TAG is only a label and does -->
   <!-- not need to match the XML element/attribute structure.                     -->
   <!-- INDX follows the Ethernet input wiring in nebumind_demoserver_rsi.rsix.   -->

<SEND>
      <ELEMENTS>
       <ELEMENT TAG="DEF_RIst" TYPE="DOUBLE" INDX="INTERNAL" />
       <ELEMENT TAG="DEF_AIPos" TYPE="DOUBLE" INDX="INTERNAL" />
       <!-- Cartesian actual position $POS_ACT -> PosAct (REAL) -->
       <ELEMENT TAG="RIst_X" TYPE="DOUBLE" INDX="1" />
       <ELEMENT TAG="RIst_Y" TYPE="DOUBLE" INDX="2" />
       <ELEMENT TAG="RIst_Z" TYPE="DOUBLE" INDX="3" />
       <ELEMENT TAG="RIst_A" TYPE="DOUBLE" INDX="4" />
       <ELEMENT TAG="RIst_B" TYPE="DOUBLE" INDX="5" />
       <ELEMENT TAG="RIst_C" TYPE="DOUBLE" INDX="6" />
       <!-- Motor currents $CURR_ACT -> MotorCurrent (REAL) -->
       <ELEMENT TAG="MACur_A1" TYPE="DOUBLE" INDX="7" />
       <ELEMENT TAG="MACur_A2" TYPE="DOUBLE" INDX="8" />
       <ELEMENT TAG="MACur_A3" TYPE="DOUBLE" INDX="9" />
       <ELEMENT TAG="MACur_A4" TYPE="DOUBLE" INDX="10" />
       <ELEMENT TAG="MACur_A5" TYPE="DOUBLE" INDX="11" />
       <ELEMENT TAG="MACur_A6" TYPE="DOUBLE" INDX="12" />
       <!-- Integer status words $SEN.PINT[] -> Sen_PInt (INT) -->
       <ELEMENT TAG="Robotnumber" TYPE="LONG" INDX="13" />
       <ELEMENT TAG="PathStart" TYPE="LONG" INDX="14" />
       <ELEMENT TAG="PathEnd" TYPE="LONG" INDX="15" />
       <ELEMENT TAG="ProcessType" TYPE="LONG" INDX="16" />
       <ELEMENT TAG="RobotFinishedStep" TYPE="LONG" INDX="17" />
       <ELEMENT TAG="ModeSet" TYPE="LONG" INDX="18" />
       <ELEMENT TAG="WorkstepID" TYPE="LONG" INDX="19" />
       <ELEMENT TAG="IPOC" TYPE="LONG" INDX="20" />
      </ELEMENTS>
   </SEND>
   <RECEIVE>
      <ELEMENTS>

      </ELEMENTS>
   </RECEIVE>

